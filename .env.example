# Firebase – élő helymegosztáshoz (opcionális).
# Másold ezt a fájlt ".env" néven, és töltsd ki a saját Firebase projekted adataival.
# Amíg ezek hiányoznak, az app HELYI módban fut (nincs élő szinkron, de minden más működik).
#
# Beállítás:
#  1. https://console.firebase.google.com → "Add project" (ingyenes Spark csomag elég).
#  2. Build → Realtime Database → Create database (válassz régiót, "test mode" / lásd a szabályokat lent).
#  3. Build → Authentication → Sign-in method → Anonymous → Enable.
#  4. Project settings → "Your apps" → Web app (</>) → másold ide az alábbi értékeket.
#
# Realtime Database szabályok (csak bejelentkezett felhasználók írhatnak/olvashatnak):
#  {
#    "rules": {
#      "rooms": {
#        "$room": { ".read": "auth != null", ".write": "auth != null" }
#      }
#    }
#  }

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
